<!DOCTYPE html>
<html
    {% if existsIn(site.data, "language") %}lang="{{site.data.language}}"{% endif %}
>
    <head>
        {% include "partials/head.inja" %}
    </head>
    <body>
        {% include "partials/header.inja" %}
        <div class="flag start-flag"></div>
        <aside>
            <h2>Pages in this section</h2>
            <ul>
                {% for neighbour in listPages(site, ".") %}
                    <li><a href="{{site.site_prefix}}/{{ neighbour.url }}">{{ neighbour.title }}</a></li>
                {% endfor %}
            </ul>
        </aside>
        <main>
            {% block content %}
            {% endblock %}
        </main>
        <div class="flag end-flag"></div>
        {% include "partials/footer.inja" %}
    </body>
</html>
