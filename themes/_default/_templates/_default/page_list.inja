{% extends "base.inja" %}
{% block content %}
    {% include "content" %}

    {% if exists("listing") %}
        {% for page in listing.pages %}
            <article>
                <h2><a href="{{ site.prefix}}/{{ page.url }}">{{ page.title }}</a></h2>
            </article>
        {% endfor %}

        {% include "partials/paginator.inja" %}
    {% endif %}
{% endblock %}
